# LUXEDOWN environment variables
# Copy to .env.local for local development. Set these in the Vercel project dashboard for production.

# Optional: disable Puppeteer-based extraction locally (always disabled on Vercel)
# DISABLE_PUPPETEER=0

# Optional: allow yt-dlp/ffmpeg server-side processing on Vercel (not recommended; direct browser download is preferred)
# ENABLE_LOCAL_BINARIES=0

# --- Server-side cookies (users do not need to paste these) ---

# YouTube — export cookies.txt while logged in at youtube.com
# Option A: path to file (easiest for local dev)
# COOKIES_YOUTUBE_FILE=./secrets/youtube-cookies.txt
#
# Option B: paste Netscape cookies.txt content directly (works in Vercel dashboard)
# COOKIES_YOUTUBE=# Netscape HTTP Cookie File
# .youtube.com	TRUE	/	TRUE	1735689600	VISITOR_INFO1_LIVE	...
#
# Option C: base64-encoded cookies.txt (avoids newline issues in some hosts)
# COOKIES_YOUTUBE_BASE64=IyBOZXRzY2FwZS...

# Future platforms (same pattern):
# COOKIES_TIKTOK / COOKIES_TIKTOK_FILE / COOKIES_TIKTOK_BASE64
# COOKIES_DOUYIN / COOKIES_DOUYIN_FILE / COOKIES_DOUYIN_BASE64
