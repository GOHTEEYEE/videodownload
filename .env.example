# LUXEDOWN environment variables
# Copy to .env.local for local development. Set these in the Vercel project dashboard for production.

# Optional: disable Puppeteer-based extraction locally (always disabled on Vercel)
# DISABLE_PUPPETEER=0

# Optional: allow yt-dlp/ffmpeg server-side processing on Vercel (not recommended; direct browser download is preferred)
# ENABLE_LOCAL_BINARIES=0
